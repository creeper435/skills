# Jira Configuration for create-task skill
# Copy this file to .env and fill in your actual values

# Your Jira subdomain (without .atlassian.net)
# Example: If your Jira URL is https://mycompany.atlassian.net, use "mycompany"
JIRA_SUBDOMAIN=your-domain

# Your Jira account email
JIRA_USERNAME=your.email@company.com

# Your Jira API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Default project key for searches (can be overridden in queries)
# Example: CWS, DEV, PROJ
JIRA_PROJECT_KEY=TASK

# ============================================================
# HOW TO GET YOUR API TOKEN:
# ============================================================
# 1. Go to: https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Give it a name (e.g., "Claude Agent")
# 4. Copy the token and paste it above in JIRA_API_TOKEN
#
# IMPORTANT: Never commit the .env file to version control!
# Add .env to your .gitignore file.
# ============================================================

# Your Jira Asignee ID
JIRA_ASIGNEE_ID=your_api_token_here
